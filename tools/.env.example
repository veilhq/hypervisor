# ADO Stats Collector Configuration
#
# Authentication (pick one):
#   1. (Preferred) Run 'az login' — uses cached Azure CLI credentials automatically
#   2. (Fallback)  Set ADO_PAT below for Personal Access Token auth
#
# If azure-identity is installed and you're logged in via 'az login',
# no PAT is needed. The collector will use your cached session.

# ADO_PAT=your-personal-access-token-here

ADO_ORG=CyberInnovationCenter
ADO_PROJECT=Cyber.org
ADO_TEAM=Cyber.org Team
